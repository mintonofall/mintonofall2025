// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model User {
  id      Int      @id @default(autoincrement())
  userName String   @unique
  nickName String @default("")
  password String
  point Int @default(10000)
  clubs Club[] @relation("UserClubs")
  clubDiaries ClubDiary[]
  createat DateTime? @default(now())
  myTeam        FantasyTeam[]
  fantasyLeagues FantasyLeague[] @relation("FantasyLeagueParticipants")
}

model FantasyTeam {
  id     Int  @id @default(autoincrement())
  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  fantasyLeagueId Int
  fantasyLeague   FantasyLeague @relation(fields: [fantasyLeagueId], references: [id], onDelete: Cascade)
}

enum GameEvent {
  MS
  WS
  MD
  WD
  XD
}

model FantasyPlayer {
  id    Int       @id @default(autoincrement())
  year  Int
  name  String
  contry String?
  photo String?
  event GameEvent
  ranking Int
  gamesAsPlayer1 FantasyGame[] @relation("Player1Games")
  gamesAsPlayer2 FantasyGame[] @relation("Player2Games")
}

model FantasyGame {
  id Int @id @default(autoincrement())
  date DateTime
  player1Id  Int
  player1    FantasyPlayer @relation("Player1Games", fields: [player1Id], references: [id], onDelete: Cascade)
  player2Id  Int
  player2    FantasyPlayer @relation("Player2Games", fields: [player2Id], references: [id], onDelete: Cascade)
  gameResult Int[]
}

model FantasyLeague {
  id Int @id @default(autoincrement())
  leagueName String
  year Int
  teams      FantasyTeam[]
  process String
  order Int[]
  currentUser Int?
  participants User[] @relation("FantasyLeagueParticipants")
}

model Club {
  id Int @id @default(autoincrement())
  clubName String @unique
  clubLogo String?
  clubDescription String?
  clubLocation String?
  users User[] @relation("UserClubs")
  howManyCourts Int @default(4)
  players Player[]

  

}

model ClubDiary {
  id Int @id @default(autoincrement())
  clubName String
  userid Int
  players PlayerDiary[]
  matches MatchDiary[]
  user User @relation(fields: [userid], references: [id])
  createat DateTime? @default(now())

}

model PlayerDiary {
  id Int @id @default(autoincrement())
  userid Int?
  name String
  grade String?
  gender String?
  age Int?
  avater String?
  clubid Int
  club ClubDiary @relation(fields: [clubid], references: [id])
  mmr Int @default(1000)
  isMe Boolean @default(false)
  lastGameDate DateTime?
  createat DateTime? @default(now())
}

model MatchDiary {
  id Int @id @default(autoincrement())
  userid Int?
  gameid String? 
  players Int[]
  club ClubDiary @relation(fields: [clubid], references: [id])
  clubid Int
  winner1id Int?
  winner2id Int?
  startTime DateTime?
  endTime DateTime?
  duration Int?
  score1 Int?
  score2 Int?
  createat DateTime @default(now())
}

model Player {
  id Int @id @default(autoincrement())
  name String 
  grade String
  gender String @default("man")
  age Int?
  avater String?
  clubid Int
  club Club @relation(fields: [clubid], references: [id], onDelete: Cascade)
  suttlePoint Int @default(10000)
  waitPlayerLists WaitPlayerList[]
  waitGames WaitGame[]
  win Int @default(0)
  lose Int @default(0)
  games Int @default(0)
  mmr Int @default(1000)
  gameDatas DateTime[]
  winDatas String[]
  loseDatas String[]
  enterDatas DateTime[]
  createat DateTime @default(now())


}

model WaitPlayerList {
  id Int @id @default(autoincrement())
  clubid Int
  Playerid Int
  player Player @relation(fields: [Playerid], references: [id], onDelete: Cascade)
  enterDate DateTime
  exitDate DateTime?
}

model WaitGame {
  id Int @id @default(autoincrement())
  clubid Int
  playerid Int
  player Player @relation(fields: [playerid], references: [id])
  point Int
  updateTime DateTime? @updatedAt
}

model Match {
  id Int @id @default(autoincrement())
  gameid String 
  player1id Int
  player2id Int
  player3id Int
  player4id Int
  clubid Int
  winner1id Int?
  winner2id Int?
  startTime DateTime @default(now())
  endTime DateTime?
  duration Int?
  score1 Int?
  score2 Int?
}

model GameBoard {
  id Int @id @default(autoincrement())
  gameid String 
  clubid Int
  CourtNumber Int
  updateTime DateTime? @updatedAt
  player1id Int
  player2id Int
  player3id Int
  player4id Int
}
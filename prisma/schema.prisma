generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id      Int      @id @default(autoincrement())
  userName String   @unique
  password String
  point Int @default(10000)
  clubs Club[] @relation("UserClubs")


}

model Club {
  id Int @id @default(autoincrement())
  clubName String @unique
  clubLogo String?
  clubDescription String?
  clubLocation String?
  users User[] @relation("UserClubs")
  players Player[]

  

}

model Player {
  id Int @id @default(autoincrement())
  name String @unique
  grade String
  age Int
  avater String?
  clubid Int
  club Club @relation(fields: [clubid], references: [id])
  suttlePoint Int @default(10000)
  win Int @default(0)
  lose Int @default(0)
  games Int @default(0)
  mmr Int @default(1000)


}

model WaitPlayerList {
  id Int @id @default(autoincrement())
  clubid Int
  Playerid Int
  enterDate DateTime
  exitDate DateTime?
}
